{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "browser": true,
    "builtin": true,
    "es2024": true,
    "node": true
  },
  "plugins": ["eslint", "import", "oxc", "promise", "typescript", "unicorn", "vue"],
  "categories": {
    "correctness": "error",
    "suspicious": "error"
  },
  "rules": {
    // This is needed for importing CSS modules, as well as modules that don't
    // export anything but are intentionally imported for their side effects
    // (e.g. jest-dom for environment setup during testing.)
    "import/no-unassigned-import": "off",

    // Clearly separate type imports from regular JavaScript
    "typescript/consistent-type-imports": "error",

    // Consistently use const if possible
    "prefer-const": ["error", { "destructuring": "all" }],

    // Conflicts with SonarCloud
    "promise/always-return": "off"
  },
  "ignorePatterns": ["public/mockServiceWorker.js"]
}
